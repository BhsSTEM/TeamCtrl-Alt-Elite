<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="Item Description"
        android:textColorHint="@color/text_grey"
        app:hintTextColor="@color/accent_green"
        app:boxStrokeColor="@color/accent_green">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/checklistItemInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:inputType="textCapSentences" />
    </com.google.android.material.textfield.TextInputLayout>

    <ImageButton
        android:id="@+id/removeChecklistItemButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Remove checklist item"
        android:src="@drawable/ic_minus"
        app:tint="@color/text_grey" />

</LinearLayout>